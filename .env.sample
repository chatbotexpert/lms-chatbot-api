# OpenAI API Key for Chat, Embeddings, and Vision
OPENAI_API_KEY=

# PostgreSQL database connection URL (asyncpg driver is required)
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/dbname

# Secret API Key used for securing backend endpoints (passed in X-API-Key or Authorization Bearer)
LMS_API_KEY=

# Allowed origins for CORS (comma-separated list, or * for all)
ALLOWED_ORIGINS=*

# Delay in seconds between processing individual lessons during batch ingestion (to prevent OpenAI rate limits)
BATCH_INGEST_DELAY=2.0
